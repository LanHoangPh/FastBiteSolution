<UserControl x:Class="FastBiteGroup.Desktop.UI.Views.NavigationRailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:components="clr-namespace:FastBiteGroup.Desktop.UI.Views.Components"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="64">

    <Grid Background="{DynamicResource SidebarBrush}">
        <!-- Border on the right to separate rail from chat list -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"/>

        <Grid Margin="0,16">
            <Grid.RowDefinitions>
                <!-- Row 0: User Profile Avatar -->
                <RowDefinition Height="Auto" />
                <!-- Row 1: Navigation Actions (Middle) -->
                <RowDefinition Height="*" />
                <!-- Row 2: Settings & Utility Actions (Bottom) -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 1. Top Section: Avatar with Context Menu for Logout -->
            <components:Avatar Grid.Row="0" 
                               Initials="{Binding UserInitials}" 
                               Size="Medium" 
                               Status="Online" 
                               HorizontalAlignment="Center" 
                               Cursor="Hand"
                               MouseLeftButtonDown="Avatar_MouseLeftButtonDown"
                               Margin="0,0,0,24">
                <components:Avatar.ContextMenu>
                    <ContextMenu Background="{DynamicResource SidebarBrush}" Foreground="{DynamicResource ForegroundBrush}">
                        <!-- Display user full name and email -->
                        <MenuItem Header="{Binding CurrentUser.FullName, TargetNullValue=User}" IsEnabled="False" FontWeight="Bold"/>
                        <MenuItem Header="{Binding CurrentUser.Email}" IsEnabled="False"/>
                        <Separator/>
                        <MenuItem Header="Đăng xuất" Command="{Binding LogoutCommand}">
                            <MenuItem.Icon>
                                <Path Data="M19,3H5C3.89,3 3,3.89 3,5V9H5V5H19V19H5V15H3V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M10.08,15.58L11.5,17L16.5,12L11.5,7L10.08,8.41L12.67,11H3V13H12.67L10.08,15.58Z" 
                                      Fill="{DynamicResource ForegroundBrush}" Width="16" Height="16" Stretch="Uniform"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </components:Avatar.ContextMenu>
            </components:Avatar>

            <!-- 2. Middle Section: Main Navigation Buttons -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                <!-- Messages/Conversations (Active state look) -->
                <components:IconButton Variant="Ghost" Size="Medium" ToolTip="{DynamicResource NavMessagesTooltip}" Margin="0,0,0,16">
                    <components:IconButton.Icon>
                        <Path Data="{StaticResource QuickChatIcon}" 
                              Fill="{DynamicResource MutedForegroundBrush}" Width="20" Height="20"/>
                    </components:IconButton.Icon>
                </components:IconButton>

                <!-- Contacts -->
                <components:IconButton Variant="Ghost" Size="Medium" ToolTip="{DynamicResource NavContactsTooltip}" Margin="0,0,0,16">
                    <components:IconButton.Icon>
                        <Path Data="{StaticResource ContactIcon}" 
                              Fill="{DynamicResource MutedForegroundBrush}" Width="20" Height="20"/>
                    </components:IconButton.Icon>
                </components:IconButton>

                <!-- To-do / Tasks -->
                <components:IconButton Variant="Ghost" Size="Medium" ToolTip="{DynamicResource NavTasksTooltip}">
                    <components:IconButton.Icon>
                        <Path Data="{StaticResource ClipboardCheckIcon}" 
                              Fill="{DynamicResource MutedForegroundBrush}" Width="20" Height="20"/>
                    </components:IconButton.Icon>
                </components:IconButton>
            </StackPanel>

            <!-- 3. Bottom Section: Utility Buttons -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                <!-- Cloud Storage -->
                <components:IconButton Variant="Ghost" Size="Medium" ToolTip="{DynamicResource NavCloudTooltip}" Margin="0,0,0,16">
                    <components:IconButton.Icon>
                        <Path Data="{StaticResource CloudIcon}" 
                              Fill="{DynamicResource MutedForegroundBrush}" Width="20" Height="20"/>
                    </components:IconButton.Icon>
                </components:IconButton>

                <!-- Folder / Local Files -->
                <components:IconButton Variant="Ghost" Size="Medium" ToolTip="{DynamicResource NavFilesTooltip}" Margin="0,0,0,16">
                    <components:IconButton.Icon>
                        <Path Data="{StaticResource DocumentFolderIcon}" 
                              Fill="{DynamicResource MutedForegroundBrush}" Width="20" Height="20"/>
                    </components:IconButton.Icon>
                </components:IconButton>

                <!-- Settings (Gear) -->
                <components:IconButton Variant="Ghost" Size="Medium" ToolTip="{DynamicResource NavSettingsTooltip}">
                    <components:IconButton.Icon>
                        <Path Data="{StaticResource SettingsIcon}" 
                              Fill="{DynamicResource MutedForegroundBrush}" Width="20" Height="20"/>
                    </components:IconButton.Icon>
                </components:IconButton>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
