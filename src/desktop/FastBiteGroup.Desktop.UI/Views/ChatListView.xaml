<UserControl x:Class="FastBiteGroup.Desktop.UI.Views.ChatListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:components="clr-namespace:FastBiteGroup.Desktop.UI.Views.Components"
             xmlns:viewmodels="clr-namespace:FastBiteGroup.Desktop.UI.ViewModels"
             xmlns:converters="clr-namespace:FastBiteGroup.Desktop.UI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="300"
             d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:BooleanToBadgeStatusConverter x:Key="BoolToBadgeStatus" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource MutedBrush}">
        <!-- Border on the right to separate chat list from welcome screen -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"/>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Row 0: Search & Actions -->
                <RowDefinition Height="56" />
                <!-- Row 1: Filter Tabs (Ưu tiên / Khác) -->
                <RowDefinition Height="Auto" />
                <!-- Row 2: Conversation List -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 1. Search Box Area -->
            <Grid Grid.Row="0" Margin="16,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <components:SearchBox Grid.Column="0" PlaceholderText="{DynamicResource SearchPlaceholder}" Height="32"/>

                <components:IconButton Grid.Column="1" Variant="Ghost" Size="Small" Margin="8,0,0,0" ToolTip="{DynamicResource AddFriendTooltip}">
                    <components:IconButton.Icon>
                        <Path Data="{StaticResource PersonAddIcon}" 
                              Fill="{DynamicResource MutedForegroundBrush}" Width="16" Height="16"/>
                    </components:IconButton.Icon>
                </components:IconButton>

                <components:IconButton Grid.Column="2" Variant="Ghost" Size="Small" Margin="4,0,0,0" ToolTip="{DynamicResource CreateGroupTooltip}">
                    <components:IconButton.Icon>
                        <Path Data="{StaticResource PeopleAddIcon}" 
                              Fill="{DynamicResource MutedForegroundBrush}" Width="16" Height="16"/>
                    </components:IconButton.Icon>
                </components:IconButton>
            </Grid>

            <!-- 2. Filter Tabs Area -->
            <Grid Grid.Row="1" Margin="16,0,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Content="{DynamicResource TabPriority}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" Background="Transparent" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand"/>
                <Button Grid.Column="1" Content="{DynamicResource TabOther}" Foreground="{DynamicResource MutedForegroundBrush}" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource FilterLabel}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Path Data="{StaticResource ChevronDownIcon}" Fill="{DynamicResource MutedForegroundBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- 3. List of Conversations -->
            <ListBox Grid.Row="2" 
                     ItemsSource="{Binding Conversations}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     HorizontalContentAlignment="Stretch"
                     Padding="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,0.5" Padding="12,10">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SecondaryBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:ConversationItemViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Col 0: Avatar -->
                                <ColumnDefinition Width="Auto" />
                                <!-- Col 1: Text Info -->
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <components:Avatar Grid.Column="0" 
                                               Initials="{Binding Initials}" 
                                               Size="Medium" 
                                               Status="{Binding IsOnline, Converter={StaticResource BoolToBadgeStatus}}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>

                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Top Row: Name and Time -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" 
                                               Foreground="{DynamicResource ForegroundBrush}" 
                                               FontWeight="SemiBold" 
                                               FontSize="14" 
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding TimeText}" 
                                               Foreground="{DynamicResource MutedForegroundBrush}" 
                                               FontSize="11" 
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Bottom Row: Message preview and Unread badge -->
                                <Grid Grid.Row="1" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding LastMessage}" 
                                               Foreground="{DynamicResource MutedForegroundBrush}" 
                                               FontSize="12" 
                                               TextTrimming="CharacterEllipsis"/>
                                    
                                    <!-- Unread Badge Border -->
                                    <Border x:Name="UnreadBadge" 
                                            Grid.Column="1" 
                                            Background="{DynamicResource DestructiveBrush}" 
                                            CornerRadius="9" 
                                            MinHeight="18" 
                                            MinWidth="18" 
                                            Padding="4,1" 
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding UnreadCount}" 
                                                   Foreground="{DynamicResource DestructiveForegroundBrush}" 
                                                   FontSize="10" 
                                                   FontWeight="Bold" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                        <DataTemplate.Triggers>
                            <!-- Hide badge when unread count is 0 -->
                            <DataTrigger Binding="{Binding UnreadCount}" Value="0">
                                <Setter TargetName="UnreadBadge" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
