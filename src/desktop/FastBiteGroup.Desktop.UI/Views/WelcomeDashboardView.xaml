<UserControl x:Class="FastBiteGroup.Desktop.UI.Views.WelcomeDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:components="clr-namespace:FastBiteGroup.Desktop.UI.Views.Components"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="600">

    <UserControl.Resources>
        <!-- Headerless TabControl Style to act as a Carousel container -->
        <Style x:Key="HeaderlessTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent" Margin="{TemplateBinding Padding}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <!-- Row Definitions to structure the page vertically -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />         <!-- Center Welcome & Carousel -->
            <RowDefinition Height="Auto" />      <!-- Footer Promo Area -->
        </Grid.RowDefinitions>

        <!-- Carousel Navigation Arrows (Left/Right margins) -->
        <!-- Left Arrow -->
        <components:IconButton Variant="Ghost" Size="Medium" 
                               HorizontalAlignment="Left" 
                               VerticalAlignment="Center" 
                               Margin="24,0,0,0"
                               Panel.ZIndex="10"
                               Click="PrevBtn_Click"
                               ToolTip="{DynamicResource SlidePrevTooltip}">
            <components:IconButton.Icon>
                <Path Data="{StaticResource ArrowLeftIcon}" 
                      Fill="{DynamicResource MutedForegroundBrush}" Width="24" Height="24"/>
            </components:IconButton.Icon>
        </components:IconButton>

        <!-- Right Arrow -->
        <components:IconButton Variant="Ghost" Size="Medium" 
                               HorizontalAlignment="Right" 
                               VerticalAlignment="Center" 
                               Margin="0,0,24,0"
                               Panel.ZIndex="10"
                               Click="NextBtn_Click"
                               ToolTip="{DynamicResource SlideNextTooltip}">
            <components:IconButton.Icon>
                <Path Data="{StaticResource ArrowRightIcon}" 
                      Fill="{DynamicResource MutedForegroundBrush}" Width="24" Height="24"/>
            </components:IconButton.Icon>
        </components:IconButton>

        <!-- ==================== CENTER CONTENT (CAROUSEL) ==================== -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="560" Margin="40,0">
            
            <!-- TabControl wrapper acting as Carousel pages -->
            <TabControl x:Name="CarouselTabControl" 
                        SelectedIndex="0"
                        Style="{StaticResource HeaderlessTabControlStyle}"
                        SelectionChanged="CarouselTabControl_SelectionChanged">
                
                <!-- SLIDE 1: Welcome & Hub Features -->
                <TabItem>
                    <StackPanel>
                        <!-- Slide Title -->
                        <TextBlock Text="{DynamicResource Slide1Title}" 
                                   Style="{StaticResource TitleTextBlockStyle}" 
                                   FontSize="24" 
                                   HorizontalAlignment="Center" 
                                   TextAlignment="Center"/>
                        
                        <!-- Slide Subtitle -->
                        <TextBlock Text="{DynamicResource Slide1Subtitle}" 
                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                   FontSize="14" 
                                   Margin="0,12,0,40" 
                                   HorizontalAlignment="Center" 
                                   TextAlignment="Center" 
                                   TextWrapping="Wrap"/>

                        <!-- Sharp Display Card (Separated Shadow) -->
                        <Grid HorizontalAlignment="Center">
                            <!-- Shadow border layer (rasterized on its own, preventing text blur) -->
                            <Border Background="{DynamicResource CardBrush}" 
                                    BorderBrush="{DynamicResource BorderBrush}" 
                                    BorderThickness="1" 
                                    CornerRadius="{DynamicResource RadiusLg}" 
                                    Effect="{DynamicResource ShadowSm}" />

                            <!-- Content layer (perfectly crisp vector graphics and text) -->
                            <Border Padding="28,24" CornerRadius="{DynamicResource RadiusLg}">
                                <Grid Width="460">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Vector Illustration: Laptop -->
                                    <Grid Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Ellipse Fill="{DynamicResource SidebarAccentBrush}" Width="140" Height="140" Opacity="0.5">
                                            <Ellipse.Effect>
                                                <BlurEffect Radius="20"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <Canvas Width="120" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Data="M 10 10 L 110 10 L 110 80 L 10 80 Z" Stroke="{DynamicResource ForegroundBrush}" StrokeThickness="3" Fill="{DynamicResource MutedBrush}"/>
                                            <Path Data="M 12 12 L 108 12 L 108 78 L 12 78 Z" Fill="{DynamicResource SidebarBrush}"/>
                                            <Path Data="M 35 30 H 75 V 55 H 45 L 35 65 Z" Fill="{DynamicResource PrimaryBrush}" Opacity="0.8"/>
                                            <Path Data="M 85 45 H 100 V 60 H 90 L 85 65 Z" Fill="{DynamicResource SecondaryBrush}" Opacity="0.6"/>
                                            <Path Data="M 2 82 L 118 82 L 110 92 L 10 92 Z" Stroke="{DynamicResource ForegroundBrush}" StrokeThickness="3" Fill="{DynamicResource BorderBrush}"/>
                                            <Path Data="M 50 86 H 70" Stroke="{DynamicResource MutedForegroundBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Grid>

                                    <!-- Right Feature Points -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FFFACC15" CornerRadius="16" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource QuickChatIcon}" Fill="Black" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{DynamicResource Slide1Bullet1Title}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{DynamicResource Slide1Bullet1Desc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FF4ADE80" CornerRadius="16" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource TeamsIcon}" Fill="Black" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{DynamicResource Slide1Bullet2Title}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{DynamicResource Slide1Bullet2Desc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FFF87171" CornerRadius="16" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource ContactsIcon}" Fill="Black" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{DynamicResource Slide1Bullet3Title}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{DynamicResource Slide1Bullet3Desc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FF60A5FA" CornerRadius="16" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource CreateGroupIcon}" Fill="Black" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{DynamicResource Slide1Bullet4Title}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{DynamicResource Slide1Bullet4Desc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </TabItem>

                <!-- SLIDE 2: Social & Communication -->
                <TabItem>
                    <StackPanel>
                        <!-- Slide Title -->
                        <TextBlock Text="{DynamicResource Slide2Title}" 
                                   Style="{StaticResource TitleTextBlockStyle}" 
                                   FontSize="24" 
                                   HorizontalAlignment="Center" 
                                   TextAlignment="Center"/>
                        
                        <!-- Slide Subtitle -->
                        <TextBlock Text="{DynamicResource Slide2Subtitle}" 
                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                   FontSize="14" 
                                   Margin="0,12,0,40" 
                                   HorizontalAlignment="Center" 
                                   TextAlignment="Center" 
                                   TextWrapping="Wrap"/>

                        <!-- Sharp Display Card (Separated Shadow) -->
                        <Grid HorizontalAlignment="Center">
                            <!-- Shadow border layer -->
                            <Border Background="{DynamicResource CardBrush}" 
                                    BorderBrush="{DynamicResource BorderBrush}" 
                                    BorderThickness="1" 
                                    CornerRadius="{DynamicResource RadiusLg}" 
                                    Effect="{DynamicResource ShadowSm}" />

                            <!-- Content layer -->
                            <Border Padding="28,24" CornerRadius="{DynamicResource RadiusLg}">
                                <Grid Width="460">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Vector Illustration: Community Grid -->
                                    <Grid Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Ellipse Fill="{DynamicResource SidebarAccentBrush}" Width="140" Height="140" Opacity="0.5">
                                            <Ellipse.Effect>
                                                <BlurEffect Radius="20"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <Canvas Width="120" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <!-- Connections / Networking lines -->
                                            <Line X1="60" Y1="20" X2="25" Y2="55" Stroke="{DynamicResource ForegroundBrush}" StrokeThickness="2" Opacity="0.4"/>
                                            <Line X1="60" Y1="20" X2="95" Y2="55" Stroke="{DynamicResource ForegroundBrush}" StrokeThickness="2" Opacity="0.4"/>
                                            <Line X1="25" Y1="55" X2="95" Y2="55" Stroke="{DynamicResource ForegroundBrush}" StrokeThickness="2" Opacity="0.4"/>
                                            <Line X1="60" Y1="20" X2="60" Y2="80" Stroke="{DynamicResource ForegroundBrush}" StrokeThickness="2" Opacity="0.4"/>
                                            
                                            <!-- Central Hub User Node -->
                                            <Ellipse Canvas.Left="45" Canvas.Top="5" Width="30" Height="30" Fill="{DynamicResource PrimaryBrush}"/>
                                            <Path Data="M 52,25 C 52,19 68,19 68,25 Z" Fill="{DynamicResource PrimaryForegroundBrush}"/>
                                            <Ellipse Canvas.Left="56" Canvas.Top="10" Width="8" Height="8" Fill="{DynamicResource PrimaryForegroundBrush}"/>
                                            
                                            <!-- Left User Node -->
                                            <Ellipse Canvas.Left="10" Canvas.Top="40" Width="30" Height="30" Fill="{DynamicResource SecondaryBrush}"/>
                                            <Path Data="M 17,60 C 17,54 33,54 33,60 Z" Fill="{DynamicResource SecondaryForegroundBrush}"/>
                                            <Ellipse Canvas.Left="21" Canvas.Top="45" Width="8" Height="8" Fill="{DynamicResource SecondaryForegroundBrush}"/>

                                            <!-- Right User Node -->
                                            <Ellipse Canvas.Left="80" Canvas.Top="40" Width="30" Height="30" Fill="{DynamicResource SidebarAccentBrush}" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                                            <Path Data="M 87,60 C 87,54 103,54 103,60 Z" Fill="{DynamicResource ForegroundBrush}"/>
                                            <Ellipse Canvas.Left="91" Canvas.Top="45" Width="8" Height="8" Fill="{DynamicResource ForegroundBrush}"/>

                                            <!-- Bottom Heart/Community Node -->
                                            <Ellipse Canvas.Left="48" Canvas.Top="68" Width="24" Height="24" Fill="#FFF87171"/>
                                            <!-- Path representing a mini heart inside -->
                                            <Path Data="M 60,74 L 56,78 L 54,76 C 52,74 52,72 54,72 C 56,72 58,74 60,76 C 62,74 64,72 66,72 C 68,72 68,74 66,76 Z" Fill="White"/>
                                        </Canvas>
                                    </Grid>

                                    <!-- Right Feature Points -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FF4ADE80" CornerRadius="16" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource HeartIcon}" Fill="Black" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{DynamicResource Slide2Bullet1Title}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{DynamicResource Slide2Bullet1Desc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FF60A5FA" CornerRadius="16" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource AnnouncementIcon}" Fill="Black" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{DynamicResource Slide2Bullet2Title}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{DynamicResource Slide2Bullet2Desc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FFFACC15" CornerRadius="16" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource SurveyIcon}" Fill="Black" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{DynamicResource Slide2Bullet3Title}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{DynamicResource Slide2Bullet3Desc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FFC084FC" CornerRadius="16" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource LockIcon}" Fill="Black" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{DynamicResource Slide2Bullet4Title}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{DynamicResource Slide2Bullet4Desc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </TabItem>

                <!-- SLIDE 3: Infrastructure & Scaling -->
                <TabItem>
                    <StackPanel>
                        <!-- Slide Title -->
                        <TextBlock Text="{DynamicResource Slide3Title}" 
                                   Style="{StaticResource TitleTextBlockStyle}" 
                                   FontSize="24" 
                                   HorizontalAlignment="Center" 
                                   TextAlignment="Center"/>
                        
                        <!-- Slide Subtitle -->
                        <TextBlock Text="{DynamicResource Slide3Subtitle}" 
                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                   FontSize="14" 
                                   Margin="0,12,0,40" 
                                   HorizontalAlignment="Center" 
                                   TextAlignment="Center" 
                                   TextWrapping="Wrap"/>

                        <!-- Sharp Display Card (Separated Shadow) -->
                        <Grid HorizontalAlignment="Center">
                            <!-- Shadow border layer -->
                            <Border Background="{DynamicResource CardBrush}" 
                                    BorderBrush="{DynamicResource BorderBrush}" 
                                    BorderThickness="1" 
                                    CornerRadius="{DynamicResource RadiusLg}" 
                                    Effect="{DynamicResource ShadowSm}" />

                            <!-- Content layer -->
                            <Border Padding="28,24" CornerRadius="{DynamicResource RadiusLg}">
                                <Grid Width="460">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Vector Illustration: Database Server -->
                                    <Grid Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Ellipse Fill="{DynamicResource SidebarAccentBrush}" Width="140" Height="140" Opacity="0.5">
                                            <Ellipse.Effect>
                                                <BlurEffect Radius="20"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <Canvas Width="120" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <!-- Main Server Frame -->
                                            <Border Canvas.Left="35" Canvas.Top="10" Width="50" Height="80" CornerRadius="4" BorderThickness="2" BorderBrush="{DynamicResource ForegroundBrush}" Background="{DynamicResource MutedBrush}"/>
                                            
                                            <!-- Server Drawer 1 -->
                                            <Rectangle Canvas.Left="40" Canvas.Top="20" Width="40" Height="12" RadiusX="1" RadiusY="1" Fill="{DynamicResource SidebarBrush}" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                                            <Ellipse Canvas.Left="45" Canvas.Top="24" Width="4" Height="4" Fill="#FF4ADE80"/>
                                            <Line X1="55" Y1="26" X2="75" Y2="26" Stroke="{DynamicResource MutedForegroundBrush}" StrokeThickness="1.5"/>

                                            <!-- Server Drawer 2 -->
                                            <Rectangle Canvas.Left="40" Canvas.Top="40" Width="40" Height="12" RadiusX="1" RadiusY="1" Fill="{DynamicResource SidebarBrush}" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                                            <Ellipse Canvas.Left="45" Canvas.Top="44" Width="4" Height="4" Fill="#FF4ADE80"/>
                                            <Line X1="55" Y1="46" X2="75" Y2="46" Stroke="{DynamicResource MutedForegroundBrush}" StrokeThickness="1.5"/>

                                            <!-- Server Drawer 3 -->
                                            <Rectangle Canvas.Left="40" Canvas.Top="60" Width="40" Height="12" RadiusX="1" RadiusY="1" Fill="{DynamicResource SidebarBrush}" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                                            <Ellipse Canvas.Left="45" Canvas.Top="64" Width="4" Height="4" Fill="#FF60A5FA"/>
                                            <Line X1="55" Y1="66" X2="75" Y2="66" Stroke="{DynamicResource MutedForegroundBrush}" StrokeThickness="1.5"/>

                                            <!-- Speed gauge / lightning on left side -->
                                            <Path Data="M 20,30 L 28,45 L 22,48 L 30,68 L 18,52 L 24,49 Z" Fill="#FFFACC15"/>
                                        </Canvas>
                                    </Grid>

                                    <!-- Right Feature Points -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FFC084FC" CornerRadius="16" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource DbIcon}" Fill="Black" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{DynamicResource Slide3Bullet1Title}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{DynamicResource Slide3Bullet1Desc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FFF87171" CornerRadius="16" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource CacheIcon}" Fill="Black" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{DynamicResource Slide3Bullet2Title}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{DynamicResource Slide3Bullet2Desc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FF4ADE80" CornerRadius="16" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource LinesIcon}" Fill="Black" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{DynamicResource Slide3Bullet3Title}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{DynamicResource Slide3Bullet3Desc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#FF60A5FA" CornerRadius="16" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource CloudIcon}" Fill="Black" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{DynamicResource Slide3Bullet4Title}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{DynamicResource Slide3Bullet4Desc}" Style="{StaticResource CaptionTextBlockStyle}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <!-- Carousel Pagination Dots (Dòng dưới card) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Ellipse x:Name="Dot0" Fill="{DynamicResource PrimaryBrush}" Width="8" Height="8" Margin="4,0" />
                <Ellipse x:Name="Dot1" Fill="{DynamicResource BorderBrush}" Width="8" Height="8" Margin="4,0" />
                <Ellipse x:Name="Dot2" Fill="{DynamicResource BorderBrush}" Width="8" Height="8" Margin="4,0" />
            </StackPanel>
        </StackPanel>

        <!-- ==================== FOOTER PROMO BANNER ==================== -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,40">
            <TextBlock Text="{DynamicResource FooterTitle}" 
                       Style="{StaticResource TitleTextBlockStyle}" 
                       FontSize="15" 
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" 
                       TextAlignment="Center"/>
            
            <TextBlock Text="{DynamicResource FooterDesc}" 
                       Style="{StaticResource CaptionTextBlockStyle}" 
                       FontSize="12" 
                       Margin="0,6,0,16" 
                       HorizontalAlignment="Center" 
                       TextAlignment="Center"/>
            
            <Button Content="{DynamicResource FooterBtnText}" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    HorizontalAlignment="Center" 
                    Padding="24,10"
                    Cursor="Hand" />
        </StackPanel>
    </Grid>
</UserControl>
