<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Font Families -->
    <FontFamily x:Key="LoginFontSans">Segoe UI, Inter, Arial, sans-serif</FontFamily>

    <!-- Font Sizes -->
    <System:Double x:Key="LoginFontSizeTitle" xmlns:System="clr-namespace:System;assembly=mscorlib">24</System:Double>
    <System:Double x:Key="LoginFontSizeSubtitle" xmlns:System="clr-namespace:System;assembly=mscorlib">13.5</System:Double>
    <System:Double x:Key="LoginFontSizeBody" xmlns:System="clr-namespace:System;assembly=mscorlib">14</System:Double>
    <System:Double x:Key="LoginFontSizeSmall" xmlns:System="clr-namespace:System;assembly=mscorlib">12</System:Double>

    <!-- Typography Styles -->
    <Style x:Key="LoginTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LoginFontSans}" />
        <Setter Property="FontSize" Value="{StaticResource LoginFontSizeTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource LoginTextPrimaryBrush}" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>
 
    <Style x:Key="LoginSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LoginFontSans}" />
        <Setter Property="FontSize" Value="{StaticResource LoginFontSizeSubtitle}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource LoginTextSecondaryBrush}" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="20" />
    </Style>
 
    <Style x:Key="LoginLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LoginFontSans}" />
        <Setter Property="FontSize" Value="{StaticResource LoginFontSizeSmall}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource LoginTextSecondaryBrush}" />
    </Style>

</ResourceDictionary>
