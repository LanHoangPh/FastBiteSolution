<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== BACKGROUND GRADIENTS ==================== -->
    <LinearGradientBrush x:Key="LoginBgBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFE0F2FE" Offset="0.0" />  <!-- Light Sky Blue (sky-100) -->
        <GradientStop Color="#FFE8F4FD" Offset="0.5" />
        <GradientStop Color="#FFF0F9FF" Offset="1.0" />  <!-- Very Light Blue-White (sky-50) -->
    </LinearGradientBrush>

    <!-- Decorative blur shape colors -->
    <SolidColorBrush x:Key="DecorativeArcBrush1" Color="#2638BDF2" /> <!-- 15% opacity sky blue -->
    <SolidColorBrush x:Key="DecorativeArcBrush2" Color="#1E818CF8" /> <!-- 12% opacity indigo -->

    <!-- ==================== CARD STYLING ==================== -->
    <!-- Glassmorphic Card Background (75% opacity white) -->
    <SolidColorBrush x:Key="LoginCardBgBrush" Color="#BFFFFFFF" />
    <SolidColorBrush x:Key="LoginCardBorderBrush" Color="#40FFFFFF" /> <!-- Subtle white highlight border -->
    
    <!-- Shadow Effect Color -->
    <Color x:Key="LoginShadowColor">#0F000000</Color> <!-- Very soft 9% opacity black shadow -->

    <!-- ==================== TYPOGRAPHY & TEXTS ==================== -->
    <SolidColorBrush x:Key="LoginTextPrimaryBrush" Color="#FF0F172A" />    <!-- Slate 900 -->
    <SolidColorBrush x:Key="LoginTextSecondaryBrush" Color="#FF475569" />  <!-- Slate 600 -->
    <SolidColorBrush x:Key="LoginTextMutedBrush" Color="#FF94A3B8" />      <!-- Slate 400 -->
    <SolidColorBrush x:Key="LoginLinkBrush" Color="#FF2563EB" />           <!-- Blue 600 -->
    <SolidColorBrush x:Key="LoginLinkHoverBrush" Color="#FF1D4ED8" />      <!-- Blue 700 -->

    <!-- ==================== INPUT FIELDS ==================== -->
    <SolidColorBrush x:Key="LoginInputBgBrush" Color="#FFF1F5F9" />        <!-- Slate 100 -->
    <SolidColorBrush x:Key="LoginInputActiveBorderBrush" Color="#FF94A3B8"/> <!-- Slate 400 -->
    <SolidColorBrush x:Key="LoginInputErrorBorderBrush" Color="#FFEF4444" /> <!-- Red 500 -->

    <!-- ==================== BUTTONS ==================== -->
    <SolidColorBrush x:Key="LoginPrimaryBtnBrush" Color="#FF0F172A" />      <!-- Slate 900 -->
    <SolidColorBrush x:Key="LoginPrimaryBtnHoverBrush" Color="#FF1E293B" /> <!-- Slate 800 -->
    <SolidColorBrush x:Key="LoginPrimaryBtnTextBrush" Color="#FFFFFFFF" />

    <SolidColorBrush x:Key="LoginSocialBtnBgBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="LoginSocialBtnHoverBgBrush" Color="#FFF8FAFC" /> <!-- Slate 50 -->
    <SolidColorBrush x:Key="LoginSocialBtnBorderBrush" Color="#FFE2E8F0" /> <!-- Slate 200 -->

</ResourceDictionary>
