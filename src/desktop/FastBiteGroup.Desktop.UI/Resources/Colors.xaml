<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Thương hiệu (Brand Colors) -->
    <Color x:Key="PrimaryColor">#FF6200EE</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    
    <Color x:Key="SecondaryColor">#FF03DAC6</Color>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>

    <!-- Màu nền (Backgrounds) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FFF5F5F5"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>

    <!-- Màu chữ (Text) -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF000000"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF666666"/>
    
    <!-- Màu trạng thái (Status) -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#FF4CAF50"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFFFC107"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FFF44336"/>

</ResourceDictionary>
