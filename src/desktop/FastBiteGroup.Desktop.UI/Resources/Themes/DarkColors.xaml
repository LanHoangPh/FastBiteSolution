<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryColor">#FF818CF8</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>

    <Color x:Key="SecondaryColor">#FF22D3EE</Color>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>

    <SolidColorBrush x:Key="BackgroundBrush" Color="#FF0F172A"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FF111827"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#FF1E293B"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#FF334155"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#FF1F2937"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF8FAFC"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFCBD5E1"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FF0F172A"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#FF4ADE80"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFFACC15"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FFF87171"/>

</ResourceDictionary>
