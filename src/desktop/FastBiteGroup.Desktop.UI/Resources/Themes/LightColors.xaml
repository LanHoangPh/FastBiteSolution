<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryColor">#FF4F46E5</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>

    <Color x:Key="SecondaryColor">#FF0891B2</Color>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>

    <SolidColorBrush x:Key="BackgroundBrush" Color="#FFF4F6F8"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#FFF8FAFC"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#FFE2E8F0"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#FFF1F5F9"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF111827"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF64748B"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFFFF"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#FF16A34A"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFD97706"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FFDC2626"/>

</ResourceDictionary>
