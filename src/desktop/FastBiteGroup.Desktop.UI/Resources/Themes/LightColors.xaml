<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Raw Colors (Light Mode) -->
    <Color x:Key="BackgroundColor">#FFFDFDFD</Color>
    <Color x:Key="ForegroundColor">#FF000000</Color>
    <Color x:Key="CardColor">#FFFDFDFD</Color>
    <Color x:Key="CardForegroundColor">#FF000000</Color>
    <Color x:Key="PopoverColor">#FFFCFCFC</Color>
    <Color x:Key="PopoverForegroundColor">#FF000000</Color>
    <Color x:Key="PrimaryColor">#FF51F0A8</Color>
    <Color x:Key="PrimaryForegroundColor">#FF000000</Color>
    <Color x:Key="SecondaryColor">#FFFCFDFD</Color>
    <Color x:Key="SecondaryForegroundColor">#FF080808</Color>
    <Color x:Key="MutedColor">#FFF5F5F5</Color>
    <Color x:Key="MutedForegroundColor">#FF525252</Color>
    <Color x:Key="AccentColor">#FFF9FFFC</Color>
    <Color x:Key="AccentForegroundColor">#FF0D9F5D</Color>
    <Color x:Key="DestructiveColor">#FFF54A88</Color>
    <Color x:Key="DestructiveForegroundColor">#FFFFFFFF</Color>
    <Color x:Key="BorderColor">#FFF4F6F8</Color>
    <Color x:Key="InputColor">#FFEBEBEB</Color>
    <Color x:Key="RingColor">#FF51F0A8</Color>
    <Color x:Key="GridSelectionColor">#FFE0F2FE</Color>
    <Color x:Key="GridSelectionForegroundColor">#FF0369A1</Color>

    <!-- Login Surface Colors -->
    <Color x:Key="LoginSkyTopColor">#FFE0F2FE</Color>
    <Color x:Key="LoginSkyBottomColor">#FFF0F9FF</Color>
    <Color x:Key="LoginDecorative1Color">#2638BDF2</Color>
    <Color x:Key="LoginDecorative2Color">#1E818CF8</Color>
    <Color x:Key="LoginGlassCardColor">#BFFFFFFF</Color>
    <Color x:Key="LoginGlassBorderColor">#40FFFFFF</Color>
    <Color x:Key="LoginShadowColor">#0F000000</Color>
    <Color x:Key="LoginTextPrimaryColor">#FF0F172A</Color>
    <Color x:Key="LoginTextSecondaryColor">#FF475569</Color>
    <Color x:Key="LoginTextMutedColor">#FF94A3B8</Color>
    <Color x:Key="LoginLinkColor">#FF2563EB</Color>
    <Color x:Key="LoginLinkHoverColor">#FF1D4ED8</Color>
    <Color x:Key="LoginInputBackgroundColor">#FFF1F5F9</Color>
    <Color x:Key="LoginInputBorderColor">#FF94A3B8</Color>
    <Color x:Key="LoginInputErrorBorderColor">#FFEF4444</Color>
    <Color x:Key="LoginPrimaryButtonColor">#FF0F172A</Color>
    <Color x:Key="LoginPrimaryButtonHoverColor">#FF1E293B</Color>
    <Color x:Key="LoginPrimaryButtonForegroundColor">#FFFFFFFF</Color>
    <Color x:Key="LoginSocialButtonBgColor">#FFFFFFFF</Color>
    <Color x:Key="LoginSocialButtonHoverBgColor">#FFF8FAFC</Color>
    <Color x:Key="LoginSocialButtonBorderColor">#FFE2E8F0</Color>
    
    <!-- Chart Colors -->
    <Color x:Key="Chart1Color">#FF51F0A8</Color>
    <Color x:Key="Chart2Color">#FF7EFE8F</Color>
    <Color x:Key="Chart3Color">#FFFF4838</Color>
    <Color x:Key="Chart4Color">#FF2EBDF6</Color>
    <Color x:Key="Chart5Color">#FFFFB188</Color>

    <!-- Sidebar Colors -->
    <Color x:Key="SidebarColor">#FFFFFFFF</Color>
    <Color x:Key="SidebarForegroundColor">#FF000000</Color>
    <Color x:Key="SidebarPrimaryColor">#FF000000</Color>
    <Color x:Key="SidebarPrimaryForegroundColor">#FFFFFFFF</Color>
    <Color x:Key="SidebarAccentColor">#FFE4FEF3</Color>
    <Color x:Key="SidebarAccentForegroundColor">#FF000000</Color>
    <Color x:Key="SidebarBorderColor">#FFEBEBEB</Color>
    <Color x:Key="SidebarRingColor">#FF000000</Color>

    <!-- Success, Warning, Error, Presence -->
    <Color x:Key="SuccessColor">#FF16A34A</Color>
    <Color x:Key="SuccessForegroundColor">#FFFFFFFF</Color>
    <Color x:Key="WarningColor">#FFD97706</Color>
    <Color x:Key="WarningForegroundColor">#FFFFFFFF</Color>
    <Color x:Key="ErrorColor">#FFF54A88</Color>
    <Color x:Key="ErrorForegroundColor">#FFFFFFFF</Color>
    <Color x:Key="OnlineColor">#FF22C55E</Color>
    <Color x:Key="AwayColor">#FFF59E0B</Color>
    <Color x:Key="BusyColor">#FFEF4444</Color>
    <Color x:Key="OfflineColor">#FF9CA3AF</Color>

    <!-- SolidColorBrushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource ForegroundColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="CardForegroundBrush" Color="{StaticResource CardForegroundColor}" />
    <SolidColorBrush x:Key="PopoverBrush" Color="{StaticResource PopoverColor}" />
    <SolidColorBrush x:Key="PopoverForegroundBrush" Color="{StaticResource PopoverForegroundColor}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="{StaticResource PrimaryForegroundColor}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}" />
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="{StaticResource SecondaryForegroundColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="{StaticResource MutedForegroundColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="{StaticResource AccentForegroundColor}" />
    <SolidColorBrush x:Key="DestructiveBrush" Color="{StaticResource DestructiveColor}" />
    <SolidColorBrush x:Key="DestructiveForegroundBrush" Color="{StaticResource DestructiveForegroundColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="InputBrush" Color="{StaticResource InputColor}" />
    <SolidColorBrush x:Key="RingBrush" Color="{StaticResource RingColor}" />
    <SolidColorBrush x:Key="GridSelectionBrush" Color="{StaticResource GridSelectionColor}" />
    <SolidColorBrush x:Key="GridSelectionForegroundBrush" Color="{StaticResource GridSelectionForegroundColor}" />

    <!-- Login Surface Brushes (Light Mode) -->
    <LinearGradientBrush x:Key="LoginBgBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource LoginSkyTopColor}" Offset="0.0" />
        <GradientStop Color="{StaticResource LoginSkyBottomColor}" Offset="1.0" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="DecorativeArcBrush1" Color="{StaticResource LoginDecorative1Color}" />
    <SolidColorBrush x:Key="DecorativeArcBrush2" Color="{StaticResource LoginDecorative2Color}" />
    <SolidColorBrush x:Key="LoginCardBgBrush" Color="{StaticResource LoginGlassCardColor}" />
    <SolidColorBrush x:Key="LoginCardBorderBrush" Color="{StaticResource LoginGlassBorderColor}" />
    <SolidColorBrush x:Key="LoginTextPrimaryBrush" Color="{StaticResource LoginTextPrimaryColor}" />
    <SolidColorBrush x:Key="LoginTextSecondaryBrush" Color="{StaticResource LoginTextSecondaryColor}" />
    <SolidColorBrush x:Key="LoginTextMutedBrush" Color="{StaticResource LoginTextMutedColor}" />
    <SolidColorBrush x:Key="LoginLinkBrush" Color="{StaticResource LoginLinkColor}" />
    <SolidColorBrush x:Key="LoginLinkHoverBrush" Color="{StaticResource LoginLinkHoverColor}" />
    <SolidColorBrush x:Key="LoginInputBgBrush" Color="{StaticResource LoginInputBackgroundColor}" />
    <SolidColorBrush x:Key="LoginInputActiveBorderBrush" Color="{StaticResource LoginInputBorderColor}" />
    <SolidColorBrush x:Key="LoginInputErrorBorderBrush" Color="{StaticResource LoginInputErrorBorderColor}" />
    <SolidColorBrush x:Key="LoginPrimaryBtnBrush" Color="{StaticResource LoginPrimaryButtonColor}" />
    <SolidColorBrush x:Key="LoginPrimaryBtnHoverBrush" Color="{StaticResource LoginPrimaryButtonHoverColor}" />
    <SolidColorBrush x:Key="LoginPrimaryBtnTextBrush" Color="{StaticResource LoginPrimaryButtonForegroundColor}" />
    <SolidColorBrush x:Key="LoginSocialBtnBgBrush" Color="{StaticResource LoginSocialButtonBgColor}" />
    <SolidColorBrush x:Key="LoginSocialBtnHoverBgBrush" Color="{StaticResource LoginSocialButtonHoverBgColor}" />
    <SolidColorBrush x:Key="LoginSocialBtnBorderBrush" Color="{StaticResource LoginSocialButtonBorderColor}" />

    <!-- Chart Brushes -->
    <SolidColorBrush x:Key="Chart1Brush" Color="{StaticResource Chart1Color}" />
    <SolidColorBrush x:Key="Chart2Brush" Color="{StaticResource Chart2Color}" />
    <SolidColorBrush x:Key="Chart3Brush" Color="{StaticResource Chart3Color}" />
    <SolidColorBrush x:Key="Chart4Brush" Color="{StaticResource Chart4Color}" />
    <SolidColorBrush x:Key="Chart5Brush" Color="{StaticResource Chart5Color}" />

    <!-- Sidebar Brushes -->
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="SidebarForegroundBrush" Color="{StaticResource SidebarForegroundColor}" />
    <SolidColorBrush x:Key="SidebarPrimaryBrush" Color="{StaticResource SidebarPrimaryColor}" />
    <SolidColorBrush x:Key="SidebarPrimaryForegroundBrush" Color="{StaticResource SidebarPrimaryForegroundColor}" />
    <SolidColorBrush x:Key="SidebarAccentBrush" Color="{StaticResource SidebarAccentColor}" />
    <SolidColorBrush x:Key="SidebarAccentForegroundBrush" Color="{StaticResource SidebarAccentForegroundColor}" />
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="{StaticResource SidebarBorderColor}" />
    <SolidColorBrush x:Key="SidebarRingBrush" Color="{StaticResource SidebarRingColor}" />

    <!-- Backward Compatibility Brushes -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource MutedColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ForegroundColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource MutedForegroundColor}"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="{StaticResource PrimaryForegroundColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessForegroundBrush" Color="{StaticResource SuccessForegroundColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningForegroundBrush" Color="{StaticResource WarningForegroundColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="ErrorForegroundBrush" Color="{StaticResource ErrorForegroundColor}"/>
    <SolidColorBrush x:Key="OnlineBrush" Color="{StaticResource OnlineColor}"/>
    <SolidColorBrush x:Key="AwayBrush" Color="{StaticResource AwayColor}"/>
    <SolidColorBrush x:Key="BusyBrush" Color="{StaticResource BusyColor}"/>
    <SolidColorBrush x:Key="OfflineBrush" Color="{StaticResource OfflineColor}"/>

</ResourceDictionary>
