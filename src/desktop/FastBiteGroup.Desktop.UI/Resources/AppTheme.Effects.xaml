<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 
      WPF IMPORTANT NOTE: 
      We must set x:Shared="False" on all DropShadowEffects. 
      In WPF, an Effect is a visual object that cannot be shared directly among multiple elements. 
      Setting x:Shared="False" forces WPF to instantiate a new instance every time the Style references it.
    -->
    <DropShadowEffect x:Key="Shadow2xs" x:Shared="False" Color="#000000" BlurRadius="3" ShadowDepth="1" Opacity="0.05" Direction="270" />
    <DropShadowEffect x:Key="ShadowXs" x:Shared="False" Color="#000000" BlurRadius="3" ShadowDepth="1" Opacity="0.05" Direction="270" />
    <DropShadowEffect x:Key="ShadowSm" x:Shared="False" Color="#000000" BlurRadius="4" ShadowDepth="1.5" Opacity="0.10" Direction="270" />
    <DropShadowEffect x:Key="Shadow" x:Shared="False" Color="#000000" BlurRadius="4" ShadowDepth="1.5" Opacity="0.10" Direction="270" />
    <DropShadowEffect x:Key="ShadowMd" x:Shared="False" Color="#000000" BlurRadius="6" ShadowDepth="2" Opacity="0.10" Direction="270" />
    <DropShadowEffect x:Key="ShadowLg" x:Shared="False" Color="#000000" BlurRadius="10" ShadowDepth="4" Opacity="0.10" Direction="270" />
    <DropShadowEffect x:Key="ShadowXl" x:Shared="False" Color="#000000" BlurRadius="16" ShadowDepth="8" Opacity="0.10" Direction="270" />
    <DropShadowEffect x:Key="Shadow2xl" x:Shared="False" Color="#000000" BlurRadius="24" ShadowDepth="12" Opacity="0.25" Direction="270" />

</ResourceDictionary>
