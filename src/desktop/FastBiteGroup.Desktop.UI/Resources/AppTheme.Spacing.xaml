<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Radius Tokens -->
    <CornerRadius x:Key="RadiusSm">18</CornerRadius>
    <CornerRadius x:Key="RadiusMd">20</CornerRadius>
    <CornerRadius x:Key="RadiusLg">22</CornerRadius>
    <CornerRadius x:Key="RadiusXl">26</CornerRadius>

    <!-- Spacing Tokens (as Thickness) -->
    <Thickness x:Key="SpacingXs">4</Thickness>
    <Thickness x:Key="SpacingSm">8</Thickness>
    <Thickness x:Key="SpacingMd">12</Thickness>
    <Thickness x:Key="SpacingLg">16</Thickness>
    <Thickness x:Key="SpacingXl">24</Thickness>
    <Thickness x:Key="SpacingXxl">32</Thickness>

    <!-- UI Component Paddings -->
    <Thickness x:Key="ControlPadding">14,10</Thickness>
    <Thickness x:Key="CardPadding">20</Thickness>
    <Thickness x:Key="WindowPadding">24</Thickness>

</ResourceDictionary>
