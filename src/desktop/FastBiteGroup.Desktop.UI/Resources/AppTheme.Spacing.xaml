<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Radius Tokens -->
    <CornerRadius x:Key="RadiusSm">18</CornerRadius>
    <CornerRadius x:Key="RadiusMd">20</CornerRadius>
    <CornerRadius x:Key="RadiusLg">22</CornerRadius>
    <CornerRadius x:Key="RadiusXl">26</CornerRadius>

    <!-- Spacing Tokens (as Thickness) -->
    <Thickness x:Key="SpacingXs">4</Thickness>
    <Thickness x:Key="SpacingSm">8</Thickness>
    <Thickness x:Key="SpacingMd">12</Thickness>
    <Thickness x:Key="SpacingLg">16</Thickness>
    <Thickness x:Key="SpacingXl">24</Thickness>
    <Thickness x:Key="SpacingXxl">32</Thickness>

    <!-- UI Component Paddings -->
    <Thickness x:Key="ControlPadding">14,10</Thickness>
    <Thickness x:Key="CardPadding">20</Thickness>
    <Thickness x:Key="WindowPadding">24</Thickness>

    <!-- Component Dimensions -->
    <system:Double x:Key="IconSizeSm">12</system:Double>
    <system:Double x:Key="IconSizeMd">16</system:Double>
    <system:Double x:Key="IconSizeLg">20</system:Double>
    
    <system:Double x:Key="IconButtonSizeSm">28</system:Double>
    <system:Double x:Key="IconButtonSizeMd">36</system:Double>
    <system:Double x:Key="IconButtonSizeLg">44</system:Double>

    <Thickness x:Key="FocusRingThickness">2</Thickness>

</ResourceDictionary>
