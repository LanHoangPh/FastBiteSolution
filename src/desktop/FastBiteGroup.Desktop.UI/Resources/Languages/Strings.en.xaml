<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ==================== HEADER BAR ==================== -->
    <sys:String x:Key="AppTitleText">FastBite Desktop</sys:String>
    <sys:String x:Key="DarkModeLabel">Dark Mode</sys:String>
    <sys:String x:Key="LanguageLabel">Language:</sys:String>

    <!-- ==================== NAVIGATION RAIL ==================== -->
    <sys:String x:Key="NavMessagesTooltip">Messages</sys:String>
    <sys:String x:Key="NavContactsTooltip">Contacts</sys:String>
    <sys:String x:Key="NavTasksTooltip">Tasks</sys:String>
    <sys:String x:Key="NavCloudTooltip">Cloud Drive</sys:String>
    <sys:String x:Key="NavFilesTooltip">Files</sys:String>
    <sys:String x:Key="NavSettingsTooltip">Settings</sys:String>

    <!-- ==================== CHAT LIST PANEL ==================== -->
    <sys:String x:Key="SearchPlaceholder">Search</sys:String>
    <sys:String x:Key="TabPriority">Priority</sys:String>
    <sys:String x:Key="TabOther">Other</sys:String>
    <sys:String x:Key="FilterLabel">Filters</sys:String>
    <sys:String x:Key="AddFriendTooltip">Add Friend</sys:String>
    <sys:String x:Key="CreateGroupTooltip">Create Group</sys:String>

    <!-- ==================== WELCOME DASHBOARD ==================== -->
    <sys:String x:Key="SlidePrevTooltip">Previous slide</sys:String>
    <sys:String x:Key="SlideNextTooltip">Next slide</sys:String>

    <!-- Slide 1 -->
    <sys:String x:Key="Slide1Title">Welcome to FastBite!</sys:String>
    <sys:String x:Key="Slide1Subtitle">Discover tools to work and chat with colleagues optimized for your PC.</sys:String>
    <sys:String x:Key="Slide1Bullet1Title">Quick Messages</sys:String>
    <sys:String x:Key="Slide1Bullet1Desc">Super fast replies in conversations</sys:String>
    <sys:String x:Key="Slide1Bullet2Title">Teams Identity</sys:String>
    <sys:String x:Key="Slide1Bullet2Desc">Establish trust within the enterprise</sys:String>
    <sys:String x:Key="Slide1Bullet3Title">Expand Contacts</sys:String>
    <sys:String x:Key="Slide1Bullet3Desc">Easily connect with new colleagues</sys:String>
    <sys:String x:Key="Slide1Bullet4Title">Optimize Workgroups</sys:String>
    <sys:String x:Key="Slide1Bullet4Desc">Advanced project management for teams</sys:String>

    <!-- Slide 2 -->
    <sys:String x:Key="Slide2Title">Connect Internal Communities</sys:String>
    <sys:String x:Key="Slide2Subtitle">A space to share knowledge, news, and enterprise activities to keep teams connected.</sys:String>
    <sys:String x:Key="Slide2Bullet1Title">Internal Social Network</sys:String>
    <sys:String x:Key="Slide2Bullet1Desc">Share company stories &amp; events</sys:String>
    <sys:String x:Key="Slide2Bullet2Title">Communication Channels</sys:String>
    <sys:String x:Key="Slide2Bullet2Desc">Instant announcements from leadership</sys:String>
    <sys:String x:Key="Slide2Bullet3Title">Surveys &amp; Polls</sys:String>
    <sys:String x:Key="Slide2Bullet3Desc">Gather votes in real-time</sys:String>
    <sys:String x:Key="Slide2Bullet4Title">Enterprise Security</sys:String>
    <sys:String x:Key="Slide2Bullet4Desc">End-to-end encryption for sensitive data</sys:String>

    <!-- Slide 3 -->
    <sys:String x:Key="Slide3Title">Resilient &amp; High-Speed Infrastructure</sys:String>
    <sys:String x:Key="Slide3Subtitle">Combining SQL and MongoDB to optimize instant message responses under 10ms.</sys:String>
    <sys:String x:Key="Slide3Bullet1Title">MongoDB Database</sys:String>
    <sys:String x:Key="Slide3Bullet1Desc">Handling millions of messages daily</sys:String>
    <sys:String x:Key="Slide3Bullet2Title">Redis Caching</sys:String>
    <sys:String x:Key="Slide3Bullet2Desc">Temporary storage, responses under 10ms</sys:String>
    <sys:String x:Key="Slide3Bullet3Title">Outbox Architecture</sys:String>
    <sys:String x:Key="Slide3Bullet3Desc">Reliable and safe data synchronization</sys:String>
    <sys:String x:Key="Slide3Bullet4Title">Multi-Tenant Support</sys:String>
    <sys:String x:Key="Slide3Bullet4Desc">Secure workspace segregation</sys:String>

    <!-- Footer -->
    <sys:String x:Key="FooterTitle">Effective communication with FastBite Business Pro</sys:String>
    <sys:String x:Key="FooterDesc">Enhance team connectivity, unlimited file storage, and total end-to-end security.</sys:String>
    <sys:String x:Key="FooterBtnText">Learn More</sys:String>

    <!-- ==================== LOGIN ==================== -->
    <sys:String x:Key="LoginWindowTitle">Sign in - FastBite</sys:String>
    <sys:String x:Key="LoginBrandName">FastBite</sys:String>
    <sys:String x:Key="LoginTitle">Sign in with email</sys:String>
    <sys:String x:Key="LoginSubtitle">Bring messages, data, and teams together in a secure workspace.</sys:String>
    <sys:String x:Key="LoginEmailPlaceholder">Email</sys:String>
    <sys:String x:Key="LoginPasswordPlaceholder">Password</sys:String>
    <sys:String x:Key="LoginForgotPassword">Forgot password?</sys:String>
    <sys:String x:Key="LoginPrimaryButton">Get Started</sys:String>
    <sys:String x:Key="LoginDividerText">Or sign in with</sys:String>
    <sys:String x:Key="LoginGoogleTooltip">Continue with Google</sys:String>
    <sys:String x:Key="LoginFacebookTooltip">Continue with Facebook</sys:String>
    <sys:String x:Key="LoginMicrosoftTooltip">Continue with Microsoft</sys:String>
    <sys:String x:Key="LoginAppleTooltip">Continue with Apple</sys:String>
    <sys:String x:Key="LoginVietnameseLanguage">Vietnamese</sys:String>
    <sys:String x:Key="LoginEnglishLanguage">English</sys:String>
    <sys:String x:Key="LoginNoAccount">Don't have an account? Sign up</sys:String>

    <!-- ==================== REGISTER ==================== -->
    <sys:String x:Key="RegisterWindowTitle">Sign up - FastBite</sys:String>
    <sys:String x:Key="RegisterTitle">Create your account</sys:String>
    <sys:String x:Key="RegisterSubtitle">Join FastBite today to start collaborating with your team.</sys:String>
    <sys:String x:Key="RegisterFirstNamePlaceholder">First name</sys:String>
    <sys:String x:Key="RegisterLastNamePlaceholder">Last name</sys:String>
    <sys:String x:Key="RegisterConfirmPasswordPlaceholder">Confirm password</sys:String>
    <sys:String x:Key="RegisterDayOfBirthPlaceholder">Date of birth (dd/MM/yyyy)</sys:String>
    <sys:String x:Key="RegisterButton">Sign Up</sys:String>
    <sys:String x:Key="RegisterDividerText">Or sign up with</sys:String>
    <sys:String x:Key="RegisterBackToLogin">Already have an account? Sign in</sys:String>

    <!-- ==================== COMMON CAPTION TOOLTIPS ==================== -->
    <sys:String x:Key="MinimizeTooltip">Minimize</sys:String>
    <sys:String x:Key="MaximizeTooltip">Maximize</sys:String>
    <sys:String x:Key="RestoreTooltip">Restore Down</sys:String>
    <sys:String x:Key="CloseTooltip">Close</sys:String>

    <!-- ==================== VALIDATION ERRORS ==================== -->
    <sys:String x:Key="ValidationErrorEmailEmpty">Email is required.</sys:String>
    <sys:String x:Key="ValidationErrorEmailInvalid">Invalid Email format.</sys:String>
    <sys:String x:Key="ValidationErrorPasswordEmpty">Password is required.</sys:String>
    <sys:String x:Key="ValidationErrorPasswordLength">Password must be at least 6 characters.</sys:String>
    <sys:String x:Key="ValidationErrorConfirmPasswordEmpty">Please confirm your password.</sys:String>
    <sys:String x:Key="ValidationErrorConfirmPasswordMismatch">Passwords do not match.</sys:String>
    <sys:String x:Key="ValidationErrorLastNameEmpty">Last name is required.</sys:String>
    <sys:String x:Key="ValidationErrorFirstNameEmpty">First name is required.</sys:String>
    <sys:String x:Key="ValidationErrorDayOfBirthEmpty">Please enter your Date of Birth.</sys:String>
    <sys:String x:Key="ValidationErrorDayOfBirthInvalid">Invalid Date of Birth or you must be at least 12 years old.</sys:String>
</ResourceDictionary>
