<Window x:Class="FastBiteGroup.Desktop.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:FastBiteGroup.Desktop.UI.Views.Components"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:FastBiteGroup.Desktop.UI.Views"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitleText}" 
        Height="780" Width="1180"
        MinWidth="950" MinHeight="650"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <!-- Custom WindowChrome & Style Triggers for responsive layout -->
    <Window.Style>
        <Style TargetType="Window" BasedOn="{StaticResource AppWindowStyle}">
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <shell:WindowChrome CaptionHeight="40" 
                                        ResizeBorderThickness="6" 
                                        GlassFrameThickness="0" 
                                        CornerRadius="0"
                                        UseAeroCaptionButtons="False" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="WindowState" Value="Maximized">
                    <!-- Fix window border bleed when maximized -->
                    <Setter Property="Padding" Value="8" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Style>
        
    <Window.Resources>
        <!-- Modern Caption Buttons Style -->
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource MutedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#E81123"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#F1707A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: Top Header Bar (Height=40 for compact Zalo style) -->
            <RowDefinition Height="40" />
            <!-- Row 1: Main Work Area -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ==================== ROW 0: HEADER BAR ==================== -->
        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Left: Brand Title -->
                    <ColumnDefinition Width="*" />
                    <!-- Right: Theme Switch + Caption Buttons -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left Branding -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="6" Width="24" Height="24" shell:WindowChrome.IsHitTestVisibleInChrome="False">
                        <TextBlock Text="F" FontWeight="Bold" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{DynamicResource AppTitleText}" Style="{StaticResource TitleTextBlockStyle}" FontSize="14" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" shell:WindowChrome.IsHitTestVisibleInChrome="False"/>
                </StackPanel>

                <!-- Right Controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <!-- Language Selector -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Data="{StaticResource GlobeIcon}" 
                              Fill="{DynamicResource MutedForegroundBrush}" 
                              Width="14" 
                              Height="14" 
                              Margin="0,0,6,0"
                              VerticalAlignment="Center"/>
                        
                        <TextBlock Text="{DynamicResource LanguageLabel}" 
                                   Foreground="{DynamicResource MutedForegroundBrush}" 
                                   FontSize="12" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,8,0"/>
                        
                        <ComboBox x:Name="LanguageComboBox" 
                                  Style="{StaticResource AppComboBoxStyle}"
                                  Width="105" 
                                  Height="24"
                                  Padding="8,2"
                                  SelectedValue="{Binding CurrentLanguageCode, Mode=TwoWay}"
                                  SelectedValuePath="Tag"
                                  VerticalContentAlignment="Center"
                                  FontSize="12">
                            <ComboBoxItem Content="Tiếng Việt" Tag="vi"/>
                            <ComboBoxItem Content="English" Tag="en"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Theme Toggle Switch -->
                    <CheckBox x:Name="ThemeToggleSwitch" 
                               Content="{DynamicResource DarkModeLabel}" 
                               Style="{StaticResource ToggleSwitchStyle}" 
                               Margin="0,0,20,0" 
                               VerticalAlignment="Center"
                               IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                               shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    
                    <!-- Caption Buttons (Min, Max, Close) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="MinimizeBtn" Width="46" VerticalAlignment="Stretch" Click="MinimizeBtn_Click" ToolTip="Minimize" Style="{StaticResource CaptionButtonStyle}">
                            <Path Data="M 0 5 L 10 5" Stroke="{DynamicResource ForegroundBrush}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="MaximizeBtn" Width="46" VerticalAlignment="Stretch" Click="MaximizeBtn_Click" ToolTip="Maximize" Style="{StaticResource CaptionButtonStyle}">
                            <Path x:Name="MaximizeIcon" Data="M 1 1 L 9 1 L 9 9 L 1 9 Z" Stroke="{DynamicResource ForegroundBrush}" StrokeThickness="1.5" Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="CloseBtn" Width="46" VerticalAlignment="Stretch" Click="CloseBtn_Click" ToolTip="Close" Style="{StaticResource CaptionCloseButtonStyle}">
                            <Path Data="M 1 1 L 9 9 M 9 1 L 1 9" Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== ROW 1: WORKSPACE ==================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64" />   <!-- Col 0: Navigation Rail -->
                <ColumnDefinition Width="300" />  <!-- Col 1: Chat List Panel -->
                <ColumnDefinition Width="*" />    <!-- Col 2: Welcome Dashboard -->
            </Grid.ColumnDefinitions>

            <!-- Modular Views -->
            <views:NavigationRailView Grid.Column="0"/>
            <views:ChatListView Grid.Column="1" DataContext="{Binding}"/>
            <views:WelcomeDashboardView Grid.Column="2"/>
        </Grid>
    </Grid>
</Window>
