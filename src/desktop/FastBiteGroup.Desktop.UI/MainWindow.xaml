<Window x:Class="FastBiteGroup.Desktop.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:FastBiteGroup.Desktop.UI.Views.Components"
        mc:Ignorable="d"
        Title="{Binding AppTitle}" 
        Height="780" Width="1180"
        Style="{StaticResource AppWindowStyle}"
        WindowStartupLocation="CenterScreen">
        
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <DataTemplate x:Key="MetricCardTemplate">
            <Border Style="{StaticResource CardBorderStyle}" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="{Binding Label}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Value}" Style="{StaticResource TitleTextBlockStyle}" FontSize="24" Margin="0,4"/>
                    <TextBlock Text="{Binding Description}" Foreground="{DynamicResource AccentForegroundBrush}" Style="{StaticResource CaptionTextBlockStyle}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: Top Header Bar -->
            <RowDefinition Height="56" />
            <!-- Row 1: Main Work Area -->
            <RowDefinition Height="*" />
            <!-- Row 2: Status Bar -->
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- ==================== ROW 0: HEADER BAR ==================== -->
        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Premium App Icon -->
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="8" Width="32" Height="32">
                        <TextBlock Text="F" FontWeight="Bold" Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="FastBite Desktop" Style="{StaticResource TitleTextBlockStyle}" FontSize="20" Margin="12,0,0,0" VerticalAlignment="Center" />
                    
                    <!-- SearchBox -->
                    <components:SearchBox Width="280" Margin="32,0,0,0" PlaceholderText="Search anything..." VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Settings & Theme Dropdown -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="ThemeToggleSwitch" 
                              Content="Dark Mode" 
                              Style="{StaticResource ToggleSwitchStyle}" 
                              Margin="0,0,16,0" 
                              VerticalAlignment="Center"
                              IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"/>
                    
                    <Grid VerticalAlignment="Center">
                        <Button x:Name="SettingsButton"
                                Style="{DynamicResource HeaderMenuButtonStyle}"
                                Command="{Binding ToggleSettingsPopupCommand}"
                                Content="Appearance Settings" />

                    <!-- Custom Styled Popup to respect Dark Theme -->
                    <Popup x:Name="SettingsPopup"
                           PlacementTarget="{Binding ElementName=SettingsButton}"
                           Placement="Bottom"
                           IsOpen="{Binding IsSettingsPopupOpen}"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Slide">
                        <Border MinWidth="220"
                                Margin="0,6,0,0"
                                Background="{DynamicResource PopoverBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource RadiusMd}"
                                Effect="{DynamicResource ShadowMd}">
                            
                            <StackPanel Margin="0,4">
                                <TextBlock Margin="12,10,12,6"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Text="Switch Theme Mode" />

                                <Button x:Name="ThemeSystemButton"
                                        Style="{DynamicResource PopupMenuButtonStyle}"
                                        Command="{Binding SetSystemThemeCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Path Data="M 0 5 L 3 8 L 8 0" 
                                              Stroke="{DynamicResource AccentForegroundBrush}" 
                                              StrokeThickness="2" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Center"
                                              Visibility="{Binding IsSystemThemeSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   Text="System Default" />
                                    </Grid>
                                </Button>

                                <Button x:Name="ThemeLightButton"
                                        Style="{DynamicResource PopupMenuButtonStyle}"
                                        Command="{Binding SetLightThemeCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Path Data="M 0 5 L 3 8 L 8 0" 
                                              Stroke="{DynamicResource AccentForegroundBrush}" 
                                              StrokeThickness="2" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Center"
                                              Visibility="{Binding IsLightThemeSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   Text="Light Mode" />
                                    </Grid>
                                </Button>

                                <Button x:Name="ThemeDarkButton"
                                        Style="{DynamicResource PopupMenuButtonStyle}"
                                        Command="{Binding SetDarkThemeCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Path Data="M 0 5 L 3 8 L 8 0" 
                                              Stroke="{DynamicResource AccentForegroundBrush}" 
                                              StrokeThickness="2" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Center"
                                              Visibility="{Binding IsDarkThemeSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   Text="Dark Mode" />
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== ROW 1: WORKSPACE ==================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Sidebar Column -->
                <ColumnDefinition Width="220" />
                <!-- Content Column -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 1. Sidebar -->
            <Border Style="{StaticResource SidebarContainerStyle}" Grid.Column="0">
                <Grid Margin="10,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Nav Links -->
                    <ListBox Grid.Row="0" 
                             ItemsSource="{Binding SidebarItems}" 
                             SelectedItem="{Binding SelectedSidebarItem}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{DynamicResource RadiusMd}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource MutedBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource MutedBrush}"/>
                                                    <Setter Property="TextElement.FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="12,10">
                                    <Path Data="{Binding IconGeometry}" 
                                          Fill="{DynamicResource ForegroundBrush}"
                                          Width="18" Height="18"
                                          Margin="0,0,12,0" 
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Title}" 
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               FontSize="14"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Bottom User Card -->
                    <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <components:Avatar Initials="UA" Size="Medium" Status="Online" />
                            
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="User Admin" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="user@fastbite.local" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="12" Margin="0,2,0,0" />
                            </StackPanel>
                            
                            <components:IconButton Grid.Column="2" Variant="Ghost" Size="Small" VerticalAlignment="Center">
                                <components:IconButton.Icon>
                                    <Path Data="M12,16A2,2 0 0,1 14,18A2,2 0 0,1 12,20A2,2 0 0,1 10,18A2,2 0 0,1 12,16M12,10A2,2 0 0,1 14,12A2,2 0 0,1 12,14A2,2 0 0,1 10,12A2,2 0 0,1 12,10M12,4A2,2 0 0,1 14,6A2,2 0 0,1 12,8A2,2 0 0,1 10,6A2,2 0 0,1 12,4Z" 
                                          Fill="{DynamicResource MutedForegroundBrush}" Width="16" Height="16"/>
                                </components:IconButton.Icon>
                            </components:IconButton>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 2. Main content area -->
            <Grid Grid.Column="1" Margin="{DynamicResource WindowPadding}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Sub-Header -->
                    <RowDefinition Height="Auto" /> <!-- Analytics Cards -->
                    <RowDefinition Height="*" />    <!-- split form/grid -->
                </Grid.RowDefinitions>

                <!-- Sub header info -->
                <components:SectionHeader Grid.Row="0" Margin="0,0,0,20"
                                          Title="Workspace Dashboard"
                                          Subtitle="Manage active components and design tokens below." />

                <!-- Analytics Cards -->
                <ItemsControl ItemsSource="{Binding DashboardMetrics}" Margin="0,0,0,20" Grid.Row="1" ItemTemplate="{StaticResource MetricCardTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Split Grid -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*" />
                        <ColumnDefinition Width="6*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left panel: Form Controls -->
                    <Border Style="{StaticResource CardBorderStyle}" Grid.Column="0" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <components:SectionHeader Grid.Row="0" Margin="0,0,0,12" Title="Config Form" />

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Input Field" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox Text="Sample Input Text" Style="{StaticResource AppTextBoxStyle}" Margin="0,0,0,12" />

                                    <TextBlock Text="Password Field" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <PasswordBox Style="{StaticResource AppPasswordBoxStyle}" Margin="0,0,0,12" />

                                    <TextBlock Text="Dropdown Selector" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox SelectedIndex="0" Style="{StaticResource AppComboBoxStyle}" Margin="0,0,0,12">
                                        <ComboBoxItem Content="Item Selector 1" />
                                        <ComboBoxItem Content="Item Selector 2" />
                                        <ComboBoxItem Content="Item Selector 3" />
                                    </ComboBox>

                                    <CheckBox Content="Active Feature Token" Style="{StaticResource AppCheckBoxStyle}" Margin="0,4,0,8" IsChecked="True"/>
                                    <CheckBox Content="System Push Notification" Style="{StaticResource ToggleSwitchStyle}" Margin="0,4,0,12" IsChecked="True"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Button Area -->
                            <Grid Grid.Row="2" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <components:ModernButton Grid.Column="0" Content="Delete" Variant="Destructive" />
                                <components:ModernButton Grid.Column="2" Content="Save" Variant="Primary" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Right panel: DataGrid & Colors preview -->
                    <Grid Grid.Column="1" Margin="10,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- DataGrid Card -->
                        <Border Style="{StaticResource CardBorderStyle}" Grid.Row="0" Padding="0" ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <components:SectionHeader Grid.Row="0" Margin="16,14,16,10" Title="System Access Logs" />
                                
                                <DataGrid x:Name="AccessLogGrid" Grid.Row="1" ItemsSource="{Binding AccessLogs}" Style="{StaticResource AppDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Width="2*" Binding="{Binding Time}" />
                                        <DataGridTextColumn Header="User" Width="3*" Binding="{Binding User}" />
                                        <DataGridTextColumn Header="IP Address" Width="3*" Binding="{Binding IpAddress}" />
                                        <DataGridTextColumn Header="Status" Width="2*" Binding="{Binding Status}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- Color Swatch Card -->
                        <Border Style="{StaticResource CardBorderStyle}" Grid.Row="1" Margin="0,12,0,0" Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Theme Swatches (Chart 1 - 5)" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="13" />
                                    <TextBlock Text="Preview generated chart variables." Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="{DynamicResource Chart1Brush}" Width="20" Height="20" CornerRadius="10" Margin="4,0" ToolTip="Chart 1" />
                                    <Border Background="{DynamicResource Chart2Brush}" Width="20" Height="20" CornerRadius="10" Margin="4,0" ToolTip="Chart 2" />
                                    <Border Background="{DynamicResource Chart3Brush}" Width="20" Height="20" CornerRadius="10" Margin="4,0" ToolTip="Chart 3" />
                                    <Border Background="{DynamicResource Chart4Brush}" Width="20" Height="20" CornerRadius="10" Margin="4,0" ToolTip="Chart 4" />
                                    <Border Background="{DynamicResource Chart5Brush}" Width="20" Height="20" CornerRadius="10" Margin="4,0" ToolTip="Chart 5" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ==================== ROW 2: STATUS BAR ==================== -->
        <Border Grid.Row="2"
                Background="{DynamicResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="WPF Environment: .NET 8" />

                <TextBlock x:Name="ThemeStatusText"
                           Text="{Binding ThemeStatusText}"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource MutedForegroundBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
