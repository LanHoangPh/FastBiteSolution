<Window x:Class="FastBiteGroup.Desktop.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:behaviors="clr-namespace:FastBiteGroup.Desktop.UI.Behaviors"
        xmlns:converters="clr-namespace:FastBiteGroup.Desktop.UI.Converters"
        xmlns:components="clr-namespace:FastBiteGroup.Desktop.UI.Views.Components"
        mc:Ignorable="d"
        Title="{DynamicResource LoginWindowTitle}" 
        Height="750" Width="960"
        MinWidth="800" MinHeight="750"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />

        <!-- Self-contained caption button styles for Login Window -->
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#1A000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#33000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource LoginTextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#E81123"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#F1707A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <shell:WindowChrome CaptionHeight="50" 
                                        ResizeBorderThickness="6" 
                                        GlassFrameThickness="0" 
                                        CornerRadius="0"
                                        UseAeroCaptionButtons="False" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="WindowState" Value="Maximized">
                    <Setter Property="Padding" Value="8" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Grid Background="{StaticResource LoginBgBrush}">
        
        <!-- ==================== BACKGROUND LAYER: DECORATIVE SHAPES ==================== -->
        <Grid IsHitTestVisible="False">
            <!-- Left-Bottom Decorative Shape -->
            <Ellipse Width="480" Height="480" Fill="{StaticResource DecorativeArcBrush1}" 
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-160,0,0,-120">
                <Ellipse.Effect>
                    <BlurEffect Radius="90"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <!-- Right-Top Decorative Shape -->
            <Ellipse Width="380" Height="380" Fill="{StaticResource DecorativeArcBrush2}" 
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-100,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="70"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <!-- ==================== HEADER LAYER: CAPTION BUTTONS & DRAG ==================== -->
        <!-- Drag panel filling header area -->
        <Border Height="50" VerticalAlignment="Top" Background="Transparent" shell:WindowChrome.IsHitTestVisibleInChrome="False"/>

        <!-- Caption Controls -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Button x:Name="MinimizeBtn" Width="36" Height="36" Style="{StaticResource CaptionButtonStyle}" Click="MinimizeBtn_Click" ToolTip="{DynamicResource MinimizeTooltip}">
                <Path Data="M 0 5 L 10 5" Stroke="{StaticResource LoginTextPrimaryBrush}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
            <Button x:Name="MaximizeBtn" Width="36" Height="36"
                    Style="{StaticResource CaptionButtonStyle}" Click="MaximizeBtn_Click" ToolTip="{DynamicResource MaximizeTooltip}">
                <Path x:Name="MaximizeIcon"
                      Data="M 1 1 L 9 1 L 9 9 L 1 9 Z" Stroke="{StaticResource LoginTextPrimaryBrush}" StrokeThickness="1.5"
                      Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
            <Button x:Name="CloseBtn" Width="36" Height="36" Style="{StaticResource CaptionCloseButtonStyle}" Click="CloseBtn_Click" ToolTip="{DynamicResource CloseTooltip}">
                <Path Data="M 1 1 L 9 9 M 9 1 L 1 9"
                      Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
        </StackPanel>

        <!-- ==================== LOGO / BRAND LAYER ==================== -->
        <!--<StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="60,24,0,0" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="False">
            <Border Background="{DynamicResource LoginPrimaryBtnBrush}" CornerRadius="8" Width="28" Height="28">
                <TextBlock Text="F" FontWeight="Bold" Foreground="{DynamicResource LoginPrimaryBtnTextBrush}" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="{DynamicResource LoginBrandName}" Style="{StaticResource LoginTitleStyle}" FontSize="18" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>-->

        <!-- ==================== CENTER LAYER: AUTH CARD ==================== -->
        <Border Width="420" 
                Style="{StaticResource LoginCardStyle}" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Padding="36,28"
                shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid>
                <!-- ==================== 1. LOGIN VIEWPORT ==================== -->
                <Grid x:Name="LoginGrid" VerticalAlignment="Center">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="LoginTranslate" X="0" Y="0"/>
                    </Grid.RenderTransform>
                    <StackPanel>
                        <!-- Top Icon -->
                        <Border Width="52" Height="52" Background="{DynamicResource LoginSocialBtnBgBrush}" CornerRadius="14" HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.05" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <Path Data="{StaticResource LoginArrowIcon}"
                                  Fill="{DynamicResource LoginPrimaryBtnBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Title -->
                        <TextBlock Text="{DynamicResource LoginTitle}" Style="{StaticResource LoginTitleStyle}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <!-- Subtitle -->
                        <TextBlock Text="{DynamicResource LoginSubtitle}" Style="{StaticResource LoginSubtitleStyle}" FontSize="13" Margin="0,0,0,28"/>

                        <!-- Email Input -->
                        <components:FormTextBox x:Name="EmailInput" 
                                                Style="{StaticResource LoginFormTextBoxStyle}"
                                                Icon="{StaticResource EmailIcon}"
                                                PlaceholderText="{DynamicResource LoginEmailPlaceholder}"
                                                Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                Margin="0,0,0,24"/>

                        <!-- Password Input -->
                        <components:FormPasswordBox x:Name="PassInput" 
                                                    Style="{StaticResource LoginFormPasswordBoxStyle}"
                                                    Icon="{StaticResource LockIcon}"
                                                    PlaceholderText="{DynamicResource LoginPasswordPlaceholder}"
                                                    Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                    IsPasswordVisible="{Binding IsPasswordVisible, Mode=TwoWay}"
                                                    Margin="0,0,0,24"/>

                        <!-- Forgot Password Link -->
                        <TextBlock HorizontalAlignment="Right" Margin="0,0,0,22">
                            <Hyperlink Command="{Binding ForgotPasswordCommand}" TextDecorations="None" Foreground="{DynamicResource LoginLinkBrush}" FontSize="12" FontWeight="Medium">
                                <Hyperlink.Style>
                                    <Style TargetType="Hyperlink">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource LoginLinkHoverBrush}"/>
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Hyperlink.Style>
                                <Run Text="{DynamicResource LoginForgotPassword}"/>
                            </Hyperlink>
                        </TextBlock>

                        <!-- Primary Button -->
                        <Button Content="{DynamicResource LoginPrimaryButton}" 
                                Style="{StaticResource LoginPrimaryButtonStyle}" 
                                Command="{Binding LoginCommand}" 
                                Margin="0,0,0,24"/>

                        <!-- Divider -->
                        <Grid Margin="0,0,0,26">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="{DynamicResource LoginSocialBtnBorderBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{DynamicResource LoginDividerText}"
                                       FontSize="12" Foreground="{DynamicResource LoginTextSecondaryBrush}" Margin="12,0" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" BorderBrush="{DynamicResource LoginSocialBtnBorderBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Social Login Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <Button Style="{StaticResource LoginSocialButtonStyle}" Command="{Binding GoogleLoginCommand}" Margin="0,0,6,0" ToolTip="{DynamicResource LoginGoogleTooltip}">
                                <Image Source="{StaticResource GoogleIconImage}" Width="18" Height="18"/>
                            </Button>
                            <Button Style="{StaticResource LoginSocialButtonStyle}" Command="{Binding MicrosoftLoginCommand}" Margin="6,0,6,0" ToolTip="{DynamicResource LoginMicrosoftTooltip}">
                                <Image Source="{StaticResource MicrosoftIconImage}" Width="18" Height="18"/>
                            </Button>
                            <Button Style="{StaticResource LoginSocialButtonStyle}" Command="{Binding AppleLoginCommand}" Margin="6,0,0,0" ToolTip="{DynamicResource LoginAppleTooltip}">
                                <Path Data="{StaticResource AppleIconGeometry}" Fill="#FF000000" Width="18" Height="18" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>

                        <!-- Register Link -->
                        <TextBlock HorizontalAlignment="Center" Margin="0,12,0,0">
                            <Hyperlink Command="{Binding NavigateToRegisterViewCommand}"
                                       TextDecorations="None" Foreground="{DynamicResource LoginLinkBrush}" FontSize="12.5" FontWeight="Medium">
                                <Hyperlink.Style>
                                    <Style TargetType="Hyperlink">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource LoginLinkHoverBrush}"/>
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Hyperlink.Style>
                                <Run Text="{DynamicResource LoginNoAccount}"/>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- ==================== 2. REGISTER VIEWPORT ==================== -->
                <Grid x:Name="RegisterGrid" VerticalAlignment="Center" Visibility="Collapsed" Opacity="0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="RegisterTranslate" X="50" Y="0"/>
                    </Grid.RenderTransform>
                    <StackPanel>
                        <!-- Top Icon -->
                        <Border Width="48" Height="48" Background="{DynamicResource LoginSocialBtnBgBrush}" CornerRadius="12" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.05" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <Path Data="{StaticResource UserIcon}"
                                  Fill="{DynamicResource LoginPrimaryBtnBrush}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Title -->
                        <TextBlock Text="{DynamicResource RegisterTitle}" Style="{StaticResource LoginTitleStyle}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>

                        <!-- Subtitle -->
                        <TextBlock Text="{DynamicResource RegisterSubtitle}" Style="{StaticResource LoginSubtitleStyle}" FontSize="12.5" Margin="0,0,0,20"/>

                        <!-- Names Field (Họ & Tên song song) -->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- LastName (Họ) -->
                            <components:FormTextBox Grid.Column="0" Height="44"
                                                    x:Name="LastNameInput"
                                                    Style="{StaticResource LoginFormTextBoxStyle}"
                                                    Icon="{StaticResource UserIcon}"
                                                    PlaceholderText="{DynamicResource RegisterLastNamePlaceholder}"
                                                    Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                            <!-- FirstName (Tên) -->
                            <components:FormTextBox Grid.Column="2" Height="44"
                                                    x:Name="FirstNameInput"
                                                    Style="{StaticResource LoginFormTextBoxStyle}"
                                                    Icon="{StaticResource UserIcon}"
                                                    PlaceholderText="{DynamicResource RegisterFirstNamePlaceholder}"
                                                    Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        </Grid>

                        <!-- Email Input -->
                        <components:FormTextBox x:Name="RegEmailInput"
                                                Style="{StaticResource LoginFormTextBoxStyle}"
                                                Icon="{StaticResource EmailIcon}"
                                                PlaceholderText="{DynamicResource LoginEmailPlaceholder}"
                                                Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                Margin="0,0,0,24"/>

                        <!-- Password Input -->
                        <components:FormPasswordBox x:Name="RegPassInput" 
                                                    Style="{StaticResource LoginFormPasswordBoxStyle}"
                                                    Icon="{StaticResource LockIcon}"
                                                    PlaceholderText="{DynamicResource LoginPasswordPlaceholder}"
                                                    Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                    IsPasswordVisible="{Binding IsPasswordVisible, Mode=TwoWay}"
                                                    Margin="0,0,0,24"/>

                        <!-- Confirm Password Input -->
                        <components:FormPasswordBox x:Name="ConfirmPassInput" 
                                                    Style="{StaticResource LoginFormPasswordBoxStyle}"
                                                    Icon="{StaticResource LockIcon}"
                                                    PlaceholderText="{DynamicResource RegisterConfirmPasswordPlaceholder}"
                                                    Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                    IsPasswordVisible="{Binding IsPasswordVisible, Mode=TwoWay}"
                                                    Margin="0,0,0,24"/>

                        <!-- Date of Birth Input -->
                        <Grid Height="44" Margin="0,0,0,28">
                            <DatePicker x:Name="DoBInput" 
                                        Style="{StaticResource LoginDatePickerStyle}"
                                        SelectedDate="{Binding DayOfBirth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                        DateValidationError="DoBInput_DateValidationError"/>
                            <!-- Placeholder when DatePicker text is empty -->
                            <TextBlock Text="{DynamicResource RegisterDayOfBirthPlaceholder}"
                                       IsHitTestVisible="False" Margin="40,0,12,0" VerticalAlignment="Center" Foreground="{DynamicResource LoginTextMutedBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DayOfBirth}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Primary Button -->
                        <Button Content="{DynamicResource RegisterButton}" 
                                Style="{StaticResource LoginPrimaryButtonStyle}" 
                                Command="{Binding RegisterCommand}" 
                                Margin="0,0,0,18"/>

                        <!-- Divider -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="{DynamicResource LoginSocialBtnBorderBrush}"
                                    BorderThickness="0,0,0,1" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{DynamicResource RegisterDividerText}"
                                       FontSize="12" Foreground="{DynamicResource LoginTextSecondaryBrush}" Margin="12,0" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" BorderBrush="{DynamicResource LoginSocialBtnBorderBrush}"
                                    BorderThickness="0,0,0,1" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Social Login Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Button Style="{StaticResource LoginSocialButtonStyle}" Command="{Binding GoogleRegisterCommand}" Margin="0,0,6,0" ToolTip="{DynamicResource LoginGoogleTooltip}">
                                <Image Source="{StaticResource GoogleIconImage}" Width="18" Height="18"/>
                            </Button>
                            <Button Style="{StaticResource LoginSocialButtonStyle}" Command="{Binding MicrosoftRegisterCommand}" Margin="6,0,6,0" ToolTip="{DynamicResource LoginMicrosoftTooltip}">
                                <Image Source="{StaticResource MicrosoftIconImage}" Width="18" Height="18"/>
                            </Button>
                            <Button Style="{StaticResource LoginSocialButtonStyle}" Command="{Binding AppleRegisterCommand}" Margin="6,0,0,0" ToolTip="{DynamicResource LoginAppleTooltip}">
                                <Path Data="{StaticResource AppleIconGeometry}" Fill="#FF000000" Width="18" Height="18" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>

                        <!-- Back to Login Link -->
                        <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Hyperlink Command="{Binding BackToLoginCommand}" TextDecorations="None" Foreground="{DynamicResource LoginLinkBrush}" FontSize="12.5" FontWeight="Medium">
                                <Hyperlink.Style>
                                    <Style TargetType="Hyperlink">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource LoginLinkHoverBrush}"/>
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Hyperlink.Style>
                                <Run Text="{DynamicResource RegisterBackToLogin}"/>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
