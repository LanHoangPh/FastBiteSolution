<Window x:Class="FastBiteGroup.Desktop.UI.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:behaviors="clr-namespace:FastBiteGroup.Desktop.UI.Behaviors"
        xmlns:converters="clr-namespace:FastBiteGroup.Desktop.UI.Converters"
        mc:Ignorable="d"
        Title="{DynamicResource RegisterWindowTitle}" 
        Height="640" Width="960"
        MinWidth="800" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />

        <!-- Self-contained caption button styles for Register Window -->
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#1A000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#33000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource LoginTextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#E81123"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#F1707A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <shell:WindowChrome CaptionHeight="50" 
                                        ResizeBorderThickness="6" 
                                        GlassFrameThickness="0" 
                                        CornerRadius="0"
                                        UseAeroCaptionButtons="False" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="WindowState" Value="Maximized">
                    <Setter Property="Padding" Value="8" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Grid Background="{StaticResource LoginBgBrush}">
        
        <!-- ==================== BACKGROUND LAYER: DECORATIVE SHAPES ==================== -->
        <Grid IsHitTestVisible="False">
            <!-- Left-Bottom Decorative Shape -->
            <Ellipse Width="480" Height="480" Fill="{StaticResource DecorativeArcBrush1}" 
                      HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-160,0,0,-120">
                <Ellipse.Effect>
                    <BlurEffect Radius="90"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <!-- Right-Top Decorative Shape -->
            <Ellipse Width="380" Height="380" Fill="{StaticResource DecorativeArcBrush2}" 
                      HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-100,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="70"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <!-- ==================== HEADER LAYER: CAPTION BUTTONS & DRAG ==================== -->
        <!-- Drag panel filling header area -->
        <Border Height="50" VerticalAlignment="Top" Background="Transparent" shell:WindowChrome.IsHitTestVisibleInChrome="False"/>

        <!-- Caption Controls -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Button x:Name="MinimizeBtn" Width="36" Height="36" Style="{StaticResource CaptionButtonStyle}" Click="MinimizeBtn_Click" ToolTip="{DynamicResource MinimizeTooltip}">
                <Path Data="M 0 5 L 10 5" Stroke="{StaticResource LoginTextPrimaryBrush}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
            <Button x:Name="CloseBtn" Width="36" Height="36" Style="{StaticResource CaptionCloseButtonStyle}" Click="CloseBtn_Click" ToolTip="{DynamicResource CloseTooltip}">
                <Path Data="M 1 1 L 9 9 M 9 1 L 1 9" Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
        </StackPanel>

        <!-- ==================== LOGO / BRAND LAYER ==================== -->
        <!--<StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="60,24,0,0" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="False">
            <Border Background="{DynamicResource LoginPrimaryBtnBrush}" CornerRadius="8" Width="28" Height="28">
                <TextBlock Text="F" FontWeight="Bold" Foreground="{DynamicResource LoginPrimaryBtnTextBrush}" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="{DynamicResource LoginBrandName}" Style="{StaticResource LoginTitleStyle}" FontSize="18" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>-->

        <!-- ==================== CENTER LAYER: REGISTER CARD ==================== -->
        <Border Width="430" 
                Style="{StaticResource LoginCardStyle}" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Padding="36,28"
                shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <StackPanel VerticalAlignment="Center">
                
                <!-- 1. Top Icon -->
                <Border Width="48" Height="48" Background="{DynamicResource LoginSocialBtnBgBrush}" CornerRadius="12" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.05" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <Path Data="{StaticResource UserIcon}" Fill="{DynamicResource LoginPrimaryBtnBrush}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- 2. Title -->
                <TextBlock Text="{DynamicResource RegisterTitle}" Style="{StaticResource LoginTitleStyle}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4"/>

                <!-- 3. Subtitle -->
                <TextBlock Text="{DynamicResource RegisterSubtitle}" Style="{StaticResource LoginSubtitleStyle}" FontSize="12.5" Margin="0,0,0,20"/>

                <!-- 4. Names Field (Họ & Tên song song) -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- LastName (Họ) -->
                    <Grid Grid.Column="0" Height="44">
                        <TextBox x:Name="LastNameInput" Style="{StaticResource LoginInputStyle}" 
                                 Padding="36,11,12,11"
                                 Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"/>
                        <!-- Placeholder -->
                        <TextBlock Text="{DynamicResource RegisterLastNamePlaceholder}" IsHitTestVisible="False" Margin="36,0,12,0" VerticalAlignment="Center" Foreground="{DynamicResource LoginTextMutedBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding LastName}" Value=""/>
                                                <Condition Binding="{Binding IsFocused, ElementName=LastNameInput}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Path Data="{StaticResource UserIcon}" Fill="{DynamicResource LoginTextSecondaryBrush}" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Left" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- FirstName (Tên) -->
                    <Grid Grid.Column="2" Height="44">
                        <TextBox x:Name="FirstNameInput" Style="{StaticResource LoginInputStyle}" 
                                 Padding="36,11,12,11"
                                 Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"/>
                        <!-- Placeholder -->
                        <TextBlock Text="{DynamicResource RegisterFirstNamePlaceholder}" IsHitTestVisible="False" Margin="36,0,12,0" VerticalAlignment="Center" Foreground="{DynamicResource LoginTextMutedBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding FirstName}" Value=""/>
                                                <Condition Binding="{Binding IsFocused, ElementName=FirstNameInput}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Path Data="{StaticResource UserIcon}" Fill="{DynamicResource LoginTextSecondaryBrush}" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Left" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>

                <!-- 5. Email Input -->
                <Grid Height="44" Margin="0,0,0,10">
                    <TextBox x:Name="EmailInput" Style="{StaticResource LoginInputStyle}" 
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    <!-- Placeholder -->
                    <TextBlock Text="{DynamicResource LoginEmailPlaceholder}" IsHitTestVisible="False" Margin="40,0,12,0" VerticalAlignment="Center" Foreground="{DynamicResource LoginTextMutedBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Email}" Value=""/>
                                            <Condition Binding="{Binding IsFocused, ElementName=EmailInput}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Path Data="{StaticResource EmailIcon}" Fill="{DynamicResource LoginTextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" Margin="14,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <!-- 6. Password Input -->
                <Grid Height="44" Margin="0,0,0,10">
                    <!-- Hidden Password (PasswordBox) -->
                    <PasswordBox x:Name="PassInput" 
                                 Style="{StaticResource LoginPasswordBoxStyle}"
                                 behaviors:PasswordBoxBinding.BoundPassword="{Binding Password, Mode=TwoWay}"
                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVis}}"/>
                    
                    <!-- Revealed Password (TextBox) -->
                    <TextBox x:Name="RevealedPassInput" 
                              Style="{StaticResource LoginInputStyle}" 
                              Padding="40,11,40,11"
                              Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVis}}"/>

                    <!-- Placeholder -->
                    <TextBlock Text="{DynamicResource LoginPasswordPlaceholder}" IsHitTestVisible="False" Margin="40,0,40,0" VerticalAlignment="Center" Foreground="{DynamicResource LoginTextMutedBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Password}" Value=""/>
                                            <Condition Binding="{Binding IsFocused, ElementName=PassInput}" Value="False"/>
                                            <Condition Binding="{Binding IsFocused, ElementName=RevealedPassInput}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Left Icon -->
                    <Path Data="{StaticResource LockIcon}" Fill="{DynamicResource LoginTextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" Margin="14,0,0,0" VerticalAlignment="Center"/>

                    <!-- Right Eye Toggle -->
                    <ToggleButton IsChecked="{Binding IsPasswordVisible, Mode=TwoWay}"
                                  HorizontalAlignment="Right" 
                                  Margin="0,0,10,0" 
                                  VerticalAlignment="Center">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton" BasedOn="{StaticResource LoginEyeToggleStyle}">
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <Path Data="{StaticResource EyeOffIcon}" Fill="{DynamicResource LoginTextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <Path Data="{StaticResource EyeIcon}" Fill="{DynamicResource LoginTextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                </Grid>

                <!-- 7. Confirm Password Input -->
                <Grid Height="44" Margin="0,0,0,10">
                    <!-- Hidden Password (PasswordBox) -->
                    <PasswordBox x:Name="ConfirmPassInput" 
                                 Style="{StaticResource LoginPasswordBoxStyle}"
                                 behaviors:PasswordBoxBinding.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay}"
                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVis}}"/>
                    
                    <!-- Revealed Password (TextBox) -->
                    <TextBox x:Name="RevealedConfirmPassInput" 
                              Style="{StaticResource LoginInputStyle}" 
                              Padding="40,11,40,11"
                              Text="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVis}}"/>

                    <!-- Placeholder -->
                    <TextBlock Text="{DynamicResource RegisterConfirmPasswordPlaceholder}" IsHitTestVisible="False" Margin="40,0,40,0" VerticalAlignment="Center" Foreground="{DynamicResource LoginTextMutedBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ConfirmPassword}" Value=""/>
                                            <Condition Binding="{Binding IsFocused, ElementName=ConfirmPassInput}" Value="False"/>
                                            <Condition Binding="{Binding IsFocused, ElementName=RevealedConfirmPassInput}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Left Icon -->
                    <Path Data="{StaticResource LockIcon}" Fill="{DynamicResource LoginTextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" Margin="14,0,0,0" VerticalAlignment="Center"/>

                    <!-- Right Eye Toggle -->
                    <ToggleButton IsChecked="{Binding IsPasswordVisible, Mode=TwoWay}"
                                  HorizontalAlignment="Right" 
                                  Margin="0,0,10,0" 
                                  VerticalAlignment="Center">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton" BasedOn="{StaticResource LoginEyeToggleStyle}">
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <Path Data="{StaticResource EyeOffIcon}" Fill="{DynamicResource LoginTextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <Path Data="{StaticResource EyeIcon}" Fill="{DynamicResource LoginTextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                </Grid>

                <!-- 8. Date of Birth Input -->
                <Grid Height="44" Margin="0,0,0,18">
                    <DatePicker x:Name="DoBInput" 
                                Style="{StaticResource LoginDatePickerStyle}"
                                SelectedDate="{Binding DayOfBirth, Mode=TwoWay}"/>
                    <!-- Placeholder when DatePicker text is empty -->
                    <TextBlock Text="{DynamicResource RegisterDayOfBirthPlaceholder}" IsHitTestVisible="False" Margin="40,0,40,0" VerticalAlignment="Center" Foreground="{DynamicResource LoginTextMutedBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DayOfBirth}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Left Icon -->
                    <Path Data="{StaticResource CalendarIcon}" Fill="{DynamicResource LoginTextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" Margin="14,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>

                <!-- 9. Primary Button -->
                <Button Content="{DynamicResource RegisterButton}" 
                        Style="{StaticResource LoginPrimaryButtonStyle}" 
                        Command="{Binding RegisterCommand}" 
                        Margin="0,0,0,18"/>

                <!-- 10. Divider -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" BorderBrush="{DynamicResource LoginSocialBtnBorderBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{DynamicResource RegisterDividerText}" FontSize="12" Foreground="{DynamicResource LoginTextSecondaryBrush}" Margin="12,0" VerticalAlignment="Center"/>
                    <Border Grid.Column="2" BorderBrush="{DynamicResource LoginSocialBtnBorderBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Center"/>
                </Grid>

                <!-- 11. Social Login Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Button Style="{StaticResource LoginSocialButtonStyle}" Command="{Binding GoogleRegisterCommand}" Margin="0,0,6,0" ToolTip="{DynamicResource LoginGoogleTooltip}">
                        <Image Source="{StaticResource GoogleIconImage}" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource LoginSocialButtonStyle}" Command="{Binding MicrosoftRegisterCommand}" Margin="6,0,6,0" ToolTip="{DynamicResource LoginMicrosoftTooltip}">
                        <Image Source="{StaticResource MicrosoftIconImage}" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource LoginSocialButtonStyle}" Command="{Binding AppleRegisterCommand}" Margin="6,0,0,0" ToolTip="{DynamicResource LoginAppleTooltip}">
                        <Path Data="{StaticResource AppleIconGeometry}" Fill="#FF000000" Width="18" Height="18" Stretch="Uniform"/>
                    </Button>
                </StackPanel>

                <!-- 12. Back to Login Link -->
                <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Hyperlink Command="{Binding BackToLoginCommand}" TextDecorations="None" Foreground="{DynamicResource LoginLinkBrush}" FontSize="12.5" FontWeight="Medium">
                        <Hyperlink.Style>
                            <Style TargetType="Hyperlink">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource LoginLinkHoverBrush}"/>
                                        <Setter Property="TextDecorations" Value="Underline"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Hyperlink.Style>
                        <Run Text="{DynamicResource RegisterBackToLogin}"/>
                    </Hyperlink>
                </TextBlock>

            </StackPanel>
        </Border>
    </Grid>
</Window>
